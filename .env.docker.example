# Blue OS Docker Environment
# Copy to .env.docker and fill in your keys

# LLM provider for Blue's chat (ElizaOS uses OpenAI by default)
OPENAI_API_KEY=sk-...

# ElevenLabs for Blue's voice
ELEVENLABS_API_KEY=sk-...

# Point your Next.js app to the Docker Blue instance
# Add to your .env.local:
# ELIZA_API_BASE_URL=http://localhost:3001
