# Blue OS Server Environment
# Copy to .env and fill in your keys before running docker compose up

# Anthropic API key for Claude (same key as your ANTHROPIC_API_KEY)
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs for Blue's voice (optional)
ELEVENLABS_API_KEY=sk-...

# Then add to your Next.js .env.local:
# ELIZA_API_BASE_URL=http://localhost:3001
